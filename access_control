  else if (deniedActive) {
    int shakeOffset = (globalAnimFrame % 2 == 0) ? -3 : 3; 
    display.fillRoundRect(6 + shakeOffset, 32, 22, 18, 2, SH110X_WHITE);
    display.fillCircle(17 + shakeOffset, 39, 2, SH110X_BLACK);
    display.drawFastVLine(17 + shakeOffset, 41, 5, SH110X_BLACK);
    display.drawCircleHelper(17 + shakeOffset, 32, 7, 1|2, SH110X_WHITE);
    display.setTextSize(2); display.setCursor(38, 24); display.print("DENIED");
  } 
  else if (doorOpen) {
    int shackleSlide = (globalAnimFrame > 4) ? 5 : globalAnimFrame; 
    display.fillRoundRect(6, 34, 22, 16, 2, SH110X_WHITE);
    display.fillCircle(17, 40, 2, SH110X_BLACK);
    display.drawFastVLine(17, 42, 4, SH110X_BLACK);
    display.drawCircleHelper(17, 34 - shackleSlide, 7, 1|2, SH110X_WHITE); 
    display.setTextSize(2); display.setCursor(38, 18); display.print("OPEN");
    display.setTextSize(1); display.setCursor(38, 38); display.print(globalDisplayInfo);
  } 
  else {
    display.fillRoundRect(6, 32, 22, 18, 2, SH110X_WHITE);
    display.fillCircle(17, 39, 2, SH110X_BLACK);
    display.drawFastVLine(17, 41, 5, SH110X_BLACK);
    display.drawCircleHelper(17, 32, 7, 1|2, SH110X_WHITE);
