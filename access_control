// --- USER DATABASE STRUCTURE ---
struct User {
  byte uid[4];
  char name[16]; 
};

// --- SYSTEM VARIABLES ---
bool doorOpen = false;
bool learningMode = false;
bool autoExitLearn = false; // Smart tracker to decouple web bulk additions from standalone actions
User users[10];       
int totalCards = 0;
String pendingUsername = "Nowy Uzytkownik"; 

struct LogEntry { String time; String msg; };
