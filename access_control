#include <Arduino.h>
#include <Wire.h>

const int LED_PIN = LED_BUILTIN; // The onboard LED on your Uno R4

void setup() {
  pinMode(LED_PIN, OUTPUT);
  Wire.begin();
  
  // Fast blink 3 times on bootup so we know the code flashed successfully
  for(int i = 0; i < 3; i++) {
    digitalWrite(LED_PIN, HIGH); delay(100);
    digitalWrite(LED_PIN, LOW);  delay(100);
  }
  delay(1000);
}

void loop() {
  bool deviceFound = false;

  // Scan all possible I2C addresses (1 to 127)
  for (byte address = 1; address < 127; address++) {
    Wire.beginTransmission(address);
    byte error = Wire.endTransmission();

    if (error == 0) {
      deviceFound = true; // Something is alive out there!
      break; 
    }
  }

  if (deviceFound) {
    // SUCCESS: If the Arduino physically sees the screen, the onboard LED will blink FAST
    digitalWrite(LED_PIN, HIGH); delay(100);
    digitalWrite(LED_PIN, LOW);  delay(100);
  } else {
    // FAILURE: If there is no electrical connection, the onboard LED will pulse SLOWLY
    digitalWrite(LED_PIN, HIGH); delay(1000);
    digitalWrite(LED_PIN, LOW);  delay(1000);
  }
}