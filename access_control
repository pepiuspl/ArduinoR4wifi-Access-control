void handleProvisioningServer() {
  WiFiClient client = server.available();
  if (!client) return;
  String reqHeader = "";
  unsigned long webTimeout = millis() + 200; 
  while (client.connected() && millis() < webTimeout) { 
    if (client.available()) {
      char c = client.read(); reqHeader += c;
      if (c == '\n') break; 
    }
  }
  while (client.available()) { client.read(); }

  if (reqHeader.indexOf("POST /save_setup") != -1 || reqHeader.indexOf("GET /save_setup") != -1) {
    int sIdx = reqHeader.indexOf("s=") + 2; int pIdx = reqHeader.indexOf("&p=") + 3;
    int aIdx = reqHeader.indexOf("&a=") + 3; int tiIdx = reqHeader.indexOf("&ti=") + 4;
    int tpIdx = reqHeader.indexOf("&tp=") + 4; int teIdx = reqHeader.indexOf("&te=");

    String rawSSID = reqHeader.substring(sIdx, reqHeader.indexOf("&p="));
    String rawPass = reqHeader.substring(pIdx, reqHeader.indexOf("&a="));
    String rawAdmin = reqHeader.substring(aIdx, reqHeader.indexOf("&ti="));
    String rawTeleIP = reqHeader.substring(tiIdx, reqHeader.indexOf("&tp="));

    int spacePos = reqHeader.indexOf(" ", tpIdx); int nextAmp = reqHeader.indexOf("&", tpIdx);
    int endPortPos = (nextAmp != -1 && nextAmp < spacePos) ? nextAmp : spacePos;
    String nTelePort = reqHeader.substring(tpIdx, endPortPos);
    bool runTele = (teIdx != -1);

    String decodedSSID = urlDecode(rawSSID); String decodedPass = urlDecode(rawPass);
    String decodedAdmin = urlDecode(rawAdmin); String decodedTeleIP = urlDecode(rawTeleIP);

    saveConfiguration(decodedSSID, decodedPass, decodedAdmin, decodedTeleIP, nTelePort.toInt(), runTele, "", false, false);
    client.println("HTTP/1.1 200 OK\r\nContent-Type: text/html\r\n\r\n<html><body style='background:#121212;color:#fff;font-family:sans-serif;text-align:center;padding:50px;'><h2>💾 Ustawienia Zapisane!</h2><p>Restartowanie urzadzenia...</p></body></html>");
    delay(100); client.stop();
    tone(BUZZER_PIN, 2000, 800); delay(1000);
    NVIC_SystemReset(); return;
  }
  
  client.println("HTTP/1.1 200 OK\r\nContent-Type: text/html\r\nConnection: close\r\n");
  client.println("<!DOCTYPE html><html><head><meta charset='utf-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'>");
  client.println("<style>body{background:#121212;color:#fff;font-family:sans-serif;text-align:center;padding:20px;} .box{background:#1e1e1e;padding:20px;border-radius:10px;max-width:400px;margin:20px auto;}</style></head><body>");
  client.println("<h2>⚙️ Panel Pierwszej Konfiguracji</h2><div class='box'><form method='GET' action='/save_setup'>");
  client.println("<input type='text' name='s' placeholder='SSID Wi-Fi' required><br><input type='password' name='p' placeholder='Haslo' required><br>");
  client.println("<input type='password' name='a' placeholder='Haslo Panelu Admin' required><br>");
  client.println("<input type='text' name='ti' placeholder='IP Serwera Proxmox' value='192.168.0.100'><br>");
  client.println("<input type='text' name='tp' placeholder='Port Serwera' value='3000'><br>");
  client.println("<input type='submit' value='Zapisz i Polacz'></form></div></body></html>");
  delay(50); client.stop();
}

void executeCloudSynchronization() {
  if (strlen(proxmox_log_server) < 4) return;
  WiFiClient httpCheck;
  httpCheck.setTimeout(150);
  
  if (!httpCheck.connect(proxmox_log_server, proxmox_log_port)) return;

  httpCheck.println("GET /api/hardware/poll HTTP/1.1");
  httpCheck.print("Host: "); httpCheck.println(proxmox_log_server);
  httpCheck.println("Connection: close\r\n");

  unsigned long deadline = millis() + 150;
  String payloadResponse = ""; bool bodyStarted = false;

  while (httpCheck.connected() && millis() < deadline) {
    if (httpCheck.available()) {
      String line = httpCheck.readStringUntil('\n');
      if (line == "\r") { bodyStarted = true; continue; }
      if (bodyStarted) { payloadResponse += line; break; }
    }
  }
  httpCheck.stop();

  if (payloadResponse.indexOf("\"unlock\":true") != -1) {
    openLocalDoor("App API Remote");
  }
  
  if (payloadResponse.indexOf("\"learn\":true") != -1) {
    learningMode = true;
    int userStart = payloadResponse.indexOf("\"username\":\"") + 12;
    int userEnd = payloadResponse.indexOf("\"", userStart);
    if (userStart > 11 && userEnd > userStart) {
      pendingUsername = payloadResponse.substring(userStart, userEnd);
    }
  } else {
    learningMode = false;
  }
}

void transmitCardPayloadToCloud(String uidStr, bool runRegister) {
  if (strlen(proxmox_log_server) < 4) return;
  WiFiClient httpPost;
  httpPost.setTimeout(350);

  if (!httpPost.connect(proxmox_log_server, proxmox_log_port)) {
    tone(BUZZER_PIN, 250, 400); return;
  }

  String endpoint = runRegister ? "/api/hardware/register" : "/api/hardware/scan";
  String postData = runRegister ? "{\"uid\":\"" + uidStr + "\",\"name\":\"" + pendingUsername + "\"}" : "{\"uid\":\"" + uidStr + "\"}";

  httpPost.println("POST " + endpoint + " HTTP/1.1");
  httpPost.print("Host: "); httpPost.println(proxmox_log_server);
  httpPost.println("Content-Type: application/json");
  httpPost.print("Content-Length: "); httpPost.println(postData.length());
  httpPost.println("Connection: close\r\n");
  httpPost.print(postData);

  unsigned long deadline = millis() + 350;
  String payloadResponse = ""; bool bodyStarted = false;
  while (httpPost.connected() && millis() < deadline) {
    if (httpPost.available()) {
      String line = httpPost.readStringUntil('\n');
      if (line == "\r") { bodyStarted = true; continue; }
      if (bodyStarted) { payloadResponse += line; break; }
    }
  }
  httpPost.stop();

  if (runRegister) {
    if (payloadResponse.indexOf("\"status\":\"created\"") != -1) {
      globalAnimFrame = 0; 
      tone(BUZZER_PIN, 1000, 100); delay(100); tone(BUZZER_PIN, 1800, 300);
    } else {
      tone(BUZZER_PIN, 150, 600);
    }
  } else {
    if (payloadResponse.indexOf("\"valid\":true") != -1) {
      int nameStart = payloadResponse.indexOf("\"name\":\"") + 8;
      int nameEnd = payloadResponse.indexOf("\"", nameStart);
      String cloudName = payloadResponse.substring(nameStart, nameEnd);
      openLocalDoor(cloudName);
    } else {
      deniedActive = true; globalAnimFrame = 0;
      deniedEndTime = millis() + 1800; tone(BUZZER_PIN, 150, 600);
      digitalWrite(LED_GREEN, LOW); digitalWrite(LED_RED, HIGH);
    }
  }
}

void setup() {
  pinMode(BUZZER_PIN, OUTPUT);
  tone(BUZZER_PIN, 1200, 100); delay(100);
  
  pinMode(BUTTON_PIN, INPUT_PULLUP);
  if (digitalRead(BUTTON_PIN) == LOW) {
    delay(2000);
    if (digitalRead(BUTTON_PIN) == LOW) {
      factoryResetSettings();
    }
  }

  loadConfiguration(); loadCards(); 
  
  pinMode(RELAY_PIN, OUTPUT); pinMode(LED_GREEN, OUTPUT); pinMode(LED_RED, OUTPUT);
  pinMode(RST_PIN, OUTPUT); digitalWrite(RST_PIN, HIGH); delay(50);
  digitalWrite(RELAY_PIN, HIGH); digitalWrite(LED_GREEN, LOW); digitalWrite(LED_RED, HIGH);

  SPI.begin(); RTC.begin();
  display.begin(0x3C, true); display.clearDisplay();

  if (provisioningMode) {
    displayProvisioningInstructions(); WiFi.beginAP("ZAMEK_SETUP"); server.begin();
    tone(BUZZER_PIN, 600, 300); delay(350); tone(BUZZER_PIN, 600, 300);
    while (true) { handleProvisioningServer(); delay(10); }
  }

  WiFi.begin(ssid, pass);
  unsigned long startAttempt = millis();
  while (WiFi.status() != WL_CONNECTED && millis() - startAttempt < 10000) { delay(250); }

  if (WiFi.status() == WL_CONNECTED) {
    timeClient.begin(); timeClient.update();
    unsigned long epoch = timeClient.getEpochTime();
    if (epoch > 1000000000) { RTCTime local(epoch); RTC.setTime(local); }
    forceHardwareRFIDReset();
    tone(BUZZER_PIN, 800, 100); delay(120); tone(BUZZER_PIN, 1600, 300);
  } else {
    isOfflineStandby = true; forceHardwareRFIDReset();
    displayProvisioningInstructions("ERR: NETWORK TIMEOUT");
    WiFi.disconnect(); delay(1000); WiFi.beginAP("ZAMEK_SETUP"); delay(500); server.begin();
    tone(BUZZER_PIN, 300, 600); lastWifiRetryTime = millis(); 
  }
  lastFrameTick = millis(); lastPollTime = millis();
}

void loop() {
  if (millis() - lastFrameTick > 80) {
    lastFrameTick = millis(); globalAnimFrame++; renderSystemUI(); 
  }

  if (deniedActive && millis() > deniedEndTime) { deniedActive = false; globalDisplayInfo = ""; }

  if (isOfflineStandby) {
    handleProvisioningServer();
  } else {
    if (WiFi.status() == WL_CONNECTED && millis() - lastPollTime > 1000) {
      lastPollTime = millis();
      executeCloudSynchronization();
    }
  }

  if (rfidResetPending && !doorOpen && !deniedActive && (millis() - lastScanTime > 1200)) {
    forceHardwareRFIDReset(); rfidResetPending = false;
    globalDisplayInfo = "";
  }

  if (!rfidResetPending && !doorOpen && !deniedActive && rfid.PICC_IsNewCardPresent() && rfid.PICC_ReadCardSerial()) {
    String uidStr = "";
    for (byte i = 0; i < rfid.uid.size; i++) {
      if (rfid.uid.uidByte[i] < 0x10) uidStr += "0";
      uidStr += String(rfid.uid.uidByte[i], HEX);
      if (i < rfid.uid.size - 1) uidStr += " ";
    }
    uidStr.toUpperCase();

    transmitCardPayloadToCloud(uidStr, learningMode);

    rfid.PICC_HaltA(); rfidResetPending = true; lastScanTime = millis();
  }

  if (digitalRead(BUTTON_PIN) == LOW) {
    delay(50);
    if (digitalRead(BUTTON_PIN) == LOW) {
      openLocalDoor("PRZYCISK");
      while (digitalRead(BUTTON_PIN) == LOW);
    }
  }

  if (doorOpen && millis() > accessEndTime) {
    doorOpen = false; digitalWrite(RELAY_PIN, HIGH);
    forceHardwareRFIDReset(); rfidResetPending = false; globalDisplayInfo = "";
    digitalWrite(LED_GREEN, LOW); digitalWrite(LED_RED, HIGH);
  }
}