#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <SPI.h>
#include <MFRC522.h>
#include <WiFiS3.h> // Added native Uno R4 Wi-Fi drivers
#include <WiFiUdp.h>
#include <NTPClient.h>
#include <EEPROM.h>

// --- VERSION ---
const char* app_version = "v2.1.0 - Local Offline";

// --- WI-FI CREDENTIALS ---
const char* ssid = "YOUR_WIFI_NAME";     // Change to your network name
const char* pass = "YOUR_WIFI_PASSWORD"; // Change to your network password

// --- PINS ---
#define RELAY_PIN 4
#define BUTTON_PIN 5
#define LED_GREEN 7 
#define LED_RED 6    
#define BUZZER_PIN 8
#define RST_PIN 9
#define SS_PIN 10

// --- OBJECTS ---
Adafruit_SSD1306 display(128, 64, &Wire, -1);
MFRC522 rfid(SS_PIN, RST_PIN);
WiFiUDP ntpUDP;
NTPClient timeClient(ntpUDP, "europe.pool.ntp.org", 7200); 

// --- LOCAL SYSTEM VARIABLES ---
bool doorOpen = false;
bool learningMode = false;
byte knownUIDs[10][4]; 
int totalCards = 0;

struct LogEntry { String time; String msg; };
LogEntry lastActions[10]; 
int logCount = 0;

unsigned long accessEndTime = 0;

// --- STORAGE LOGIC ---
void loadCards() {
  EEPROM.get(0, totalCards);
  if (totalCards < 0 || totalCards > 10) totalCards = 0;
  for (int i = 0; i < totalCards; i++) {
    for (int j = 0; j < 4; j++) {
      knownUIDs[i][j] = EEPROM.read(10 + (i * 4) + j);
    }
  }
}

void saveNewCard(byte* uid) {
  if (totalCards >= 10) return;
  for (int j = 0; j < 4; j++) {
    knownUIDs[totalCards][j] = uid[j];
    EEPROM.write(10 + (totalCards * 4) + j, uid[j]);
  }
  totalCards++;
  EEPROM.write(0, totalCards);
}

// --- SYSTEM FUNCTIONS ---
void updateDisplay(String status, String info = "") {
  display.clearDisplay();
  display.setCursor(0,0);
  display.setTextSize(1);
  display.println("ZAMEK SMART R4");
  display.println(app_version);
  display.println("---------------------");
  display.println("Status: " + status);
  display.println(info);
  display.display();
}

void addLog(String msg) {
  if (WiFi.status() == WL_CONNECTED) {
    timeClient.update();
    String currentTime = timeClient.getFormattedTime();
    if (logCount < 10) {
      lastActions[logCount++] = {currentTime, msg};
    } else {
      for (int i = 0; i < 9; i++) lastActions[i] = lastActions[i+1];
      lastActions[9] = {currentTime, msg};
    }
  }
}

void openDoor(String source) {
  doorOpen = true; 
  accessEndTime = millis() + 3000;
  digitalWrite(RELAY_PIN, LOW);
  digitalWrite(LED_GREEN, HIGH);
  digitalWrite(LED_RED, LOW);
  tone(BUZZER_PIN, 1000, 200);
  updateDisplay("OTWARTE", source);
  addLog("Otwarto: " + source);
}

void setup() {
  Serial.begin(9600);
  delay(1500); 

  loadCards();
  
  pinMode(RELAY_PIN, OUTPUT);
  pinMode(LED_GREEN, OUTPUT);
  pinMode(LED_RED, OUTPUT);
  pinMode(BUTTON_PIN, INPUT_PULLUP);
  
  digitalWrite(RELAY_PIN, HIGH);
  digitalWrite(LED_GREEN, LOW);
  digitalWrite(LED_RED, HIGH);

  SPI.begin();
  rfid.PCD_Init();
  
  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  
  // Connect to Wi-Fi locally
  updateDisplay("Laczenie z WiFi...");
  WiFi.begin(ssid, pass);
  
  // Give it up to 10 seconds to connect
  unsigned long startAttempt = millis();
  while (WiFi.status() != WL_CONNECTED && millis() - startAttempt < 10000) {
    delay(500);
  }

  if (WiFi.status() == WL_CONNECTED) {
    timeClient.begin();
    updateDisplay("Gotowy", WiFi.localIP().toString());
  } else {
    updateDisplay("Gotowy", "Tryb Offline");
  }
}

void loop() {
  // --- ZARZĄDZANIE DIODAMI ---
  if (learningMode) {
    if (millis() % 500 < 250) {
      digitalWrite(LED_RED, HIGH);
      digitalWrite(LED_GREEN, LOW);
    } else {
      digitalWrite(LED_RED, LOW);
      digitalWrite(LED_GREEN, HIGH);
    }
  } else if (!doorOpen) {
    digitalWrite(LED_RED, HIGH);
    digitalWrite(LED_GREEN, LOW);
  }

  // --- SPRAWDZANIE RFID ---
  if (rfid.PICC_IsNewCardPresent() && rfid.PICC_ReadCardSerial()) {
    if (learningMode) {
      saveNewCard(rfid.uid.uidByte);
      addLog("Dodano Karte!");
      updateDisplay("DODANO KARTE", "Sukces!");
      
      digitalWrite(LED_RED, LOW);
      digitalWrite(LED_GREEN, HIGH);
      
      tone(BUZZER_PIN, 1000, 150); delay(150);
      tone(BUZZER_PIN, 1500, 150); delay(150);
      tone(BUZZER_PIN, 2000, 400); 
      
      delay(2000); 
      
      learningMode = false; 
      updateDisplay("Gotowy", WiFi.status() == WL_CONNECTED ? WiFi.localIP().toString() : "Offline");
    } else {
      bool valid = false;
      for (int i = 0; i < totalCards; i++) {
        if (memcmp(rfid.uid.uidByte, knownUIDs[i], 4) == 0) valid = true;
      }
      if (valid) openDoor("RFID");
      else {
        addLog("Odmowa RFID");
        tone(BUZZER_PIN, 200, 500);
      }
    }
    rfid.PICC_HaltA();
    rfid.PCD_StopCrypto1();
  }

  // --- FIZYCZNY PRZYCISK (Quick press = Open / Hold 3s = Learning Mode) ---
  if (digitalRead(BUTTON_PIN) == LOW) {
    unsigned long pressTime = millis();
    bool longPressed = false;

    while (digitalRead(BUTTON_PIN) == LOW) {
      if (millis() - pressTime > 3000) { 
        longPressed = true;
        learningMode = !learningMode; // Toggle mode
        
        if (learningMode) {
          rfid.PCD_Init(); 
          updateDisplay("TRYB UCZENIA", "Zbliz karte...");
          tone(BUZZER_PIN, 1500, 400);
        } else {
          updateDisplay("Gotowy", WiFi.status() == WL_CONNECTED ? WiFi.localIP().toString() : "Offline");
          tone(BUZZER_PIN, 800, 400);
        }
        while(digitalRead(BUTTON_PIN) == LOW); // Wait until button is released
        break;
      }
      delay(10);
    }

    if (!longPressed && (millis() - pressTime > 50)) {
      openDoor("Przycisk");
    }
  }

  // --- AUTO-ZAMYKANIE ---
  if (doorOpen && millis() > accessEndTime) {
    doorOpen = false;
    digitalWrite(RELAY_PIN, HIGH);
    digitalWrite(LED_GREEN, LOW);
    digitalWrite(LED_RED, HIGH);
    updateDisplay("Gotowy", WiFi.status() == WL_CONNECTED ? WiFi.localIP().toString() : "Offline");
  }
}
