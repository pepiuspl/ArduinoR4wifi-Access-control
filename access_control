#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <SPI.h>
#include <MFRC522.h>
#include <WiFiS3.h> 
#include <WiFiUdp.h>
#include <NTPClient.h>
#include <EEPROM.h>

// --- VERSION ---
const char* app_version = "v2.3.1 - User Directory";

// --- WI-FI & SECURITY CONFIGURATION ---
const char* ssid = "YOUR_WIFI_NAME";         // ⚠️ Change to your network name
const char* pass = "YOUR_WIFI_PASSWORD";     // ⚠️ Change to your network password
const String admin_password = "admin";       // 🔑 Your Web Panel access password

// --- PINS ---
#define RELAY_PIN 4
#define BUTTON_PIN 5
#define LED_GREEN 7 
#define LED_RED 6    
#define BUZZER_PIN 8
#define RST_PIN 9
#define SS_PIN 10

// --- OBJECTS ---
Adafruit_SSD1306 display(128, 64, &Wire, -1);
MFRC522 rfid(SS_PIN, RST_PIN);
WiFiUDP ntpUDP;
NTPClient timeClient(ntpUDP, "europe.pool.ntp.org", 7200); 
WiFiServer server(80); 

// --- USER DATABASE STRUCTURE ---
struct User {
  byte uid[4];
  char name[16]; // 15 characters + null terminator
};

// --- SYSTEM VARIABLES ---
bool doorOpen = false;
bool learningMode = false;
User users[10];       // Maximum database capacity of 10 named users
int totalCards = 0;
String pendingUsername = "Nowy Uzytkownik"; 

struct LogEntry { String time; String msg; };
LogEntry lastActions[10]; 
int logCount = 0;

unsigned long accessEndTime = 0;
unsigned long lastNTPUpdate = 0;

// --- WATCHDOG VARIABLES ---
bool rfidResetPending = false;
unsigned long lastScanTime = 0;

// --- STORAGE LOGIC ---
void loadCards() {
  EEPROM.get(0, totalCards);
  if (totalCards < 0 || totalCards > 10) totalCards = 0;
  
  for (int i = 0; i < totalCards; i++) {
    EEPROM.get(10 + (i * sizeof(User)), users[i]);
  }
}

void saveNewCard(byte* uid, String nameStr) {
  if (totalCards >= 10) return;
  
  memset(&users[totalCards], 0, sizeof(User));
  
  memcpy(users[totalCards].uid, uid, 4);
  nameStr.toCharArray(users[totalCards].name, 16);
  
  EEPROM.put(10 + (totalCards * sizeof(User)), users[totalCards]);
  
  totalCards++;
  EEPROM.put(0, totalCards);
}

void deleteUser(int index) {
  if (index < 0 || index >= totalCards) return;
  
  for (int i = index; i < totalCards - 1; i++) {
    users[i] = users[i + 1];
    EEPROM.put(10 + (i * sizeof(User)), users[i]);
  }
  
  totalCards--;
  EEPROM.put(0, totalCards);
}

// --- SYSTEM FUNCTIONS ---
void forceHardwareRFIDReset() {
  digitalWrite(RST_PIN, LOW);
  delay(30);
  digitalWrite(RST_PIN, HIGH);
  delay(30);
  rfid.PCD_Init(); 
}

void updateDisplay(String status, String info = "") {
  display.clearDisplay();
  display.setCursor(0,0);
  display.setTextSize(1);
  display.println("ZAMEK SMART R4");
  display.println(app_version);
  display.println("---------------------");
  display.println("Status: " + status);
  display.println(info);
  display.display();
}

void addLog(String msg) {
  String currentTime = "00:00:00";
  if (WiFi.status() == WL_CONNECTED) {
    currentTime = timeClient.getFormattedTime();
  }
  if (logCount < 10) {
    lastActions[logCount++] = {currentTime, msg};
  } else {
    for (int i = 0; i < 9; i++) lastActions[i] = lastActions[i+1];
    lastActions[9] = {currentTime, msg};
  }
}

void openDoor(String source) {
  doorOpen = true; 
  accessEndTime = millis() + 3000;
  digitalWrite(RELAY_PIN, LOW);
  digitalWrite(LED_GREEN, HIGH);
  digitalWrite(LED_RED, LOW);
  tone(BUZZER_PIN, 1000, 200);
  updateDisplay("OTWARTE", source);
  addLog("Otwarto: " + source);
}

// --- WEB SERVER INTERFACE HANDLER ---
void handleWebServer() {
  WiFiClient client = server.available();
  if (!client) return;

  String reqHeader = "";
  while (client.connected()) {
    if (client.available()) {
      char c = client.read();
      reqHeader += c;
      if (c == '\n') break; 
    }
  }
  
  while (client.available()) { client.read(); }

  bool isAuthenticated = reqHeader.indexOf("pass=" + admin_password) != -1;

  if (isAuthenticated) {
    if (reqHeader.indexOf("/unlock") != -1) {
      openDoor("Panel WWW");
    } 
    else if (reqHeader.indexOf("/toggle_learn") != -1) {
      learningMode = !learningMode;
      if (learningMode) {
        if (reqHeader.indexOf("username=") != -1) {
          int startIdx = reqHeader.indexOf("username=") + 9;
          int endIdx = reqHeader.indexOf(" ", startIdx);
          if (reqHeader.indexOf("&", startIdx) != -1 && reqHeader.indexOf("&", startIdx) < endIdx) {
            endIdx = reqHeader.indexOf("&", startIdx);
          }
          pendingUsername = reqHeader.substring(startIdx, endIdx);
          pendingUsername.replace("+", " "); 
          if(pendingUsername.length() == 0) pendingUsername = "Uzytkownik R4";
        }
        forceHardwareRFIDReset();
        updateDisplay("TRYB UCZENIA", pendingUsername);
        addLog("Tryb Ucz. [" + pendingUsername + "]");
        tone(BUZZER_PIN, 1500, 300);
      } else {
        updateDisplay("Gotowy", WiFi.localIP().toString());
        addLog("Stop Ucz: Panel WWW");
        tone(BUZZER_PIN, 800, 300);
      }
    } 
    else if (reqHeader.indexOf("/delete_user") != -1) {
      int idxPos = reqHeader.indexOf("idx=");
      if (idxPos != -1) {
        int targetIdx = reqHeader.substring(idxPos + 4, reqHeader.indexOf(" ", idxPos)).toInt();
        if (targetIdx >= 0 && targetIdx < totalCards) {
          String deletedName = String(users[targetIdx].name);
          deleteUser(targetIdx);
          addLog("Usunieto: " + deletedName);
          tone(BUZZER_PIN, 600, 400);
        }
      }
    }
  }

  client.println("HTTP/1.1 200 OK");
  client.println("Content-Type: text/html");
  client.println("Connection: close");
  client.println();
  client.println("<!DOCTYPE html><html><head><meta charset='utf-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'>");
  client.println("<style>body{background:#121212;color:#e0e0e0;font-family:sans-serif;text-align:center;padding:20px;}");
  client.println(".box{background:#1e1e1e;border-radius:10px;padding:20px;max-width:500px;margin:20px auto;box-shadow:0 4px 10px rgba(0,0,0,0.5);}");
  client.println(".btn{display:block;width:80%;margin:15px auto;padding:12px;color:#fff;font-weight:bold;border:none;border-radius:5px;cursor:pointer;text-decoration:none;font-size:16px;box-sizing:border-box;}");
  client.println(".btn-open{background:#2e7d32;} .btn-learn{background:#1565c0;} .btn-stop-learn{background:#cc3333;} .btn-login{background:#ff8f00;width:50%;}");
  client.println("input[type=password], input[type=text]{padding:10px;width:75%;border-radius:5px;border:1px solid #444;background:#2a2a2a;color:#fff;font-size:16px;text-align:center;margin-bottom:12px;box-sizing:border-box;}");
  client.println(".log-table{width:100%;text-align:left;margin-top:15px;border-collapse:collapse;} .log-table td{padding:8px;border-bottom:1px solid #333;} .time{color:#888;font-size:13px;width:80px;}</style></head><body>");

  if (!isAuthenticated) {
    client.println("<h2>🔒 Autoryzacja Zamku R4</h2>");
    client.println("<div class='box'><form method='GET' action='/'>");
    client.println("<input type='password' name='pass' placeholder='Wpisz hasło klucza' required><br>");
    client.println("<input type='submit' class='btn btn-login' value='Zaloguj'></form></div>");
  } else {
    client.println("<h2>🛠️ Panel Sterowania Access Control</h2>");
    
    client.println("<div class='box'><h3>Status Urządzenia</h3>");
    client.println("<p>Aktualny tryb: <strong>" + String(learningMode ? "<span style='color:#64b5f6;'>Tryb Uczenia Aktywny</span>" : "<span style='color:#81c784;'>Czuwanie Aktywne</span>") + "</strong></p>");
    if (learningMode) {
      client.println("<p>Oczekiwanie na przypisanie dla: <strong style='color:#ff8f00;'>" + pendingUsername + "</strong></p>");
    }
    client.println("<p>Rygiel: <strong>" + String(doorOpen ? "<span style='color:#81c784;'>OTWARTY</span>" : "<span style='color:#e57373;'>ZAMKNIĘTY</span>") + "</strong></p></div>");

    client.println("<div class='box'><h3>Działania Zdalne</h3>");
    client.println("<a href='/unlock?pass=" + admin_password + "' class='btn btn-open'>🔓 Otwórz Zamek zdalnie</a>");
    
    if (!learningMode) {
      client.println("<form method='GET' action='/toggle_learn' style='margin-top:20px;'>");
      client.println("<input type='hidden' name='pass' value='" + admin_password + "'>");
      client.println("<input type='text' name='username' placeholder='Imię i Nazwisko / Opis' maxlength='15' required><br>");
      client.println("<input type='submit' class='btn btn-learn' value='➕ Włącz Tryb Uczenia'>");
      client.println("</form>");
    } else {
      client.println("<a href='/toggle_learn?pass=" + admin_password + "' class='btn btn-stop-learn'>⏹️ Zatrzymaj Tryb Uczenia</a>");
    }
    client.println("</div>");

    client.println("<div class='box'><h3>👥 Baza Użytkowników (" + String(totalCards) + "/10)</h3>");
    if (totalCards == 0) {
      client.println("<p style='color:#777; font-style:italic;'>Baza danych jest pusta. Dodaj pierwszą kartę.</p>");
    } else {
      client.println("<table class='log-table' style='font-size:14px;'>");
      for (int i = 0; i < totalCards; i++) {
        String hexUID = "";
        for (int j = 0; j < 4; j++) {
          if (users[i].uid[j] < 0x10) hexUID += "0";
          hexUID += String(users[i].uid[j], HEX);
          if (j < 3) hexUID += " ";
        }
        hexUID.toUpperCase();
        
        client.println("<tr><td><strong>" + String(users[i].name) + "</strong><br><span style='font-size:11px;color:#666;'>" + hexUID + "</span></td>");
        client.println("<td style='text-align:right;vertical-align:middle;'><a href='/delete_user?pass=" + admin_password + "&idx=" + String(i) + "' style='color:#e57373;text-decoration:none;font-weight:bold;'>❌ Usuń</a></td></tr>");
      }
      client.println("</table>");
    }
    client.println("</div>");

    client.println("<div class='box'><h3>Dziennik Zdarzeń (Logs)</h3><table class='log-table'>");
    if (logCount == 0) {
      client.println("<tr><td>Brak zarejestrowanych akcji.</td></tr>");
    } else {
      for (int i = logCount - 1; i >= 0; i--) {
        client.println("<tr><td class='time'>[" + lastActions[i].time + "]</td><td>" + lastActions[i].msg + "</td></tr>");
      }
    }
    client.println("</table></div>");
  }
  
  client.println("<div style='margin-top: 40px; font-size: 11px; color: #555; letter-spacing: 0.5px;'>");
  client.println("System Hardware ID: Renesas RA4M1 Core | " + String(app_version));
  client.println("</div>");
  
  client.println("</body></html>");
  delay(1);
  client.stop();
}

void setup() {
  Serial.begin(9600);
  delay(1500); 

  loadCards();
  
  pinMode(RELAY_PIN, OUTPUT);
  pinMode(LED_GREEN, OUTPUT);
  pinMode(LED_RED, OUTPUT);
  pinMode(BUTTON_PIN, INPUT_PULLUP);
  
  pinMode(RST_PIN, OUTPUT); 
  digitalWrite(RST_PIN, HIGH);
  delay(50);

  digitalWrite(RELAY_PIN, HIGH);
  digitalWrite(LED_GREEN, LOW);
  digitalWrite(LED_RED, HIGH);

  SPI.begin();
  
  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  updateDisplay("Laczenie z WiFi... ");
  
  WiFi.begin(ssid, pass);
  unsigned long startAttempt = millis();
  while (WiFi.status() != WL_CONNECTED && millis() - startAttempt < 20000) {
    delay(500);
  }

  if (WiFi.status() == WL_CONNECTED) {
    timeClient.begin();
    timeClient.update();
    lastNTPUpdate = millis();
    server.begin(); 
    
    forceHardwareRFIDReset();
    
    updateDisplay("Gotowy", WiFi.localIP().toString());
    addLog("System online");

    // --- STARTUP MELODY ---
    tone(BUZZER_PIN, 800, 100);  delay(120);
    tone(BUZZER_PIN, 1000, 100); delay(120);
    tone(BUZZER_PIN, 1300, 120); delay(140);
    tone(BUZZER_PIN, 1600, 300);
  } else {
    forceHardwareRFIDReset();
    updateDisplay("Gotowy", "Tryb Offline");
    tone(BUZZER_PIN, 300, 600);
  }
}

void loop() {
  handleWebServer(); 

  // --- NON-BLOCKING WATCHDOG RESET ---
  if (rfidResetPending && !doorOpen && (millis() - lastScanTime > 1000)) {
    forceHardwareRFIDReset();
    rfidResetPending = false;
    
    if (learningMode) {
      updateDisplay("TRYB UCZENIA", pendingUsername);
    } else {
      updateDisplay("Gotowy", WiFi.status() == WL_CONNECTED ? WiFi.localIP().toString() : "Offline");
    }
  }

  // --- BACKGROUND NTP CLOCK UPDATE ---
  if (WiFi.status() == WL_CONNECTED && millis() - lastNTPUpdate > 60000) {
    timeClient.update();
    lastNTPUpdate = millis();
  }

  // --- ZARZĄDZANIE DIODAMI ---
  if (learningMode) {
    if (millis() % 500 < 250) {
      digitalWrite(LED_RED, HIGH);
      digitalWrite(LED_GREEN, LOW);
    } else {
      digitalWrite(LED_RED, LOW);
      digitalWrite(LED_GREEN, HIGH);
    }
  } else if (!doorOpen) {
    digitalWrite(LED_RED, HIGH);
    digitalWrite(LED_GREEN, LOW);
  }

  // --- SPRAWDZANIE RFID ---
  if (!rfidResetPending && !doorOpen && rfid.PICC_IsNewCardPresent() && rfid.PICC_ReadCardSerial()) {
    
    String uidStr = "";
    for (byte i = 0; i < rfid.uid.size; i++) {
      if (rfid.uid.uidByte[i] < 0x10) uidStr += "0";
      uidStr += String(rfid.uid.uidByte[i], HEX);
      if (i < rfid.uid.size - 1) uidStr += " ";
    }
    uidStr.toUpperCase();

    if (learningMode) {
      saveNewCard(rfid.uid.uidByte, pendingUsername);
      addLog("Przypisano: " + pendingUsername + " [" + uidStr + "]"); 
      updateDisplay("DODANO KARTE", pendingUsername);
      
      digitalWrite(LED_RED, LOW);
      digitalWrite(LED_GREEN, HIGH);
      
      tone(BUZZER_PIN, 1000, 150); delay(150);
      tone(BUZZER_PIN, 1500, 150); delay(150);
      tone(BUZZER_PIN, 2000, 400);
    } else {
      bool valid = false;
      int matchedIndex = -1;
      
      for (int i = 0; i < totalCards; i++) {
        if (memcmp(rfid.uid.uidByte, users[i].uid, 4) == 0) {
          valid = true;
          matchedIndex = i;
          break;
        }
      }
      
      if (valid) {
        openDoor(String(users[matchedIndex].name) + " [" + uidStr + "]"); 
      } else {
        addLog("Odmowa: Nieznany [" + uidStr + "]");
        tone(BUZZER_PIN, 200, 500);
      }
    }
    
    rfid.PICC_HaltA();
    
    rfidResetPending = true;
    lastScanTime = millis();
  }

  // --- PRZYCISK FIZYCZNY ---
  if (digitalRead(BUTTON_PIN) == LOW) {
    unsigned long pressTime = millis();
    bool longPressed = false;

    while (digitalRead(BUTTON_PIN) == LOW) {
      if (millis() - pressTime > 3000) { 
        longPressed = true;
        learningMode = !learningMode; 
        
        if (learningMode) {
          pendingUsername = "Przycisk Fiz."; 
          forceHardwareRFIDReset();
          updateDisplay("TRYB UCZENIA", pendingUsername);
          tone(BUZZER_PIN, 1500, 400);
        } else {
          updateDisplay("Gotowy", WiFi.status() == WL_CONNECTED ? WiFi.localIP().toString() : "Offline");
          tone(BUZZER_PIN, 800, 400);
        }
        while(digitalRead(BUTTON_PIN) == LOW); 
        break;
      }
      delay(10);
    }

    if (!longPressed && (millis() - pressTime > 50)) {
      openDoor("Przycisk");
    }
  }

  // --- AUTO-ZAMYKANIE ---
  if (doorOpen && millis() > accessEndTime) {
    doorOpen = false;
    digitalWrite(RELAY_PIN, HIGH); 
    
    delay(100); 
    forceHardwareRFIDReset();
    rfidResetPending = false; 

    digitalWrite(LED_GREEN, LOW);
    digitalWrite(LED_RED, HIGH);
    updateDisplay("Gotowy", WiFi.status() == WL_CONNECTED ? WiFi.localIP().toString() : "Offline");
  }
}