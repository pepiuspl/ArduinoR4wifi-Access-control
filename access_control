// --- UNIVERSAL URL DECODER UTILITY ---
String urlDecode(String str) {
  String decoded = "";
  char ch;
  int i = 0;
  while (i < str.length()) {
    if (str[i] == '+') {
      decoded += ' ';
      i++;
    } else if (str[i] == '%') {
      if (i + 2 < str.length()) {
        char high = str[i+1];
        char low = str[i+2];
        int value = 0;

        if (high >= '0' && high <= '9') value += (high - '0') * 16;
        else if (high >= 'A' && high <= 'F') value += (high - 'A' + 10) * 16;
        else if (high >= 'a' && high <= 'f') value += (high - 'a' + 10) * 16;

        if (low >= '0' && low <= '9') value += (low - '0');
        else if (low >= 'A' && low <= 'F') value += (low - 'A' + 10);
        else if (low >= 'a' && low <= 'f') value += (low - 'a' + 10);

        decoded += (char)value;
        i += 3;
      } else {
        decoded += '%';
        i++;
      }
    } else {
      decoded += str[i];
      i++;
    }
  }
  return decoded;
}

// --- STORAGE MANAGEMENT ENGINE ---
void loadConfiguration() {
  if (EEPROM.read(250) == 0x55) {
    EEPROM.get(260, ssid);
    EEPROM.get(292, pass);
    EEPROM.get(324, admin_password);
    EEPROM.get(340, proxmox_log_server);
    EEPROM.get(356, proxmox_log_port);
    telemetryEnabled = (EEPROM.read(251) == 0x01);
    EEPROM.get(360, webhook_server);
    notifyOnAccess = (EEPROM.read(424) == 0x01);
    notifyOnAlarm = (EEPROM.read(425) == 0x01);
    
    ssid[31] = '\0';
    pass[31] = '\0';
    admin_password[15] = '\0';
    proxmox_log_server[15] = '\0';
    webhook_server[63] = '\0';
    
    provisioningMode = false; 
    hasSavedConfig = true;
  } else {
    provisioningMode = true; 
    hasSavedConfig = false;
    strcpy(admin_password, "admin");
    strcpy(proxmox_log_server, "192.168.0.100"); 
    strcpy(webhook_server, "");
  }
}

void saveConfiguration(String newSSID, String newPass, String newAdmin, String newTeleIP, int newTelePort, bool enableTele, String newHookIP, bool notifAccess, bool notifAlarm) {
  memset(ssid, 0, sizeof(ssid));
  memset(pass, 0, sizeof(pass));
  memset(admin_password, 0, sizeof(admin_password));
  memset(proxmox_log_server, 0, sizeof(proxmox_log_server));
  memset(webhook_server, 0, sizeof(webhook_server));

  newSSID.toCharArray(ssid, 32);
  newPass.toCharArray(pass, 32);
  newAdmin.toCharArray(admin_password, 16);
  newTeleIP.toCharArray(proxmox_log_server, 16);
  proxmox_log_port = newTelePort;
  telemetryEnabled = enableTele;
  newHookIP.toCharArray(webhook_server, 64);
  notifyOnAccess = notifAccess;
  notifyOnAlarm = notifAlarm;

  EEPROM.put(260, ssid);
  EEPROM.put(292, pass);
  EEPROM.put(324, admin_password);
  EEPROM.put(340, proxmox_log_server);
  EEPROM.put(356, proxmox_log_port);
  EEPROM.write(251, telemetryEnabled ? 0x01 : 0x00);
  EEPROM.put(360, webhook_server);
  EEPROM.write(424, notifyOnAccess ? 0x01 : 0x00);
  EEPROM.write(425, notifyOnAlarm ? 0x01 : 0x00);
  EEPROM.write(250, 0x55); 

  hasTemporaryPassword = false;
  memset(temporary_password, 0, sizeof(temporary_password));
}

void factoryResetSettings() {
  for (int i = 0; i < 512; i++) EEPROM.write(i, 0xFF);
  EEPROM.put(0, 0); 
  totalCards = 0;
}

void loadCards() {
  EEPROM.get(0, totalCards);
  if (totalCards < 0 || totalCards > 10) totalCards = 0;
  
  for (int i = 0; i < totalCards; i++) {
    EEPROM.get(10 + (i * sizeof(User)), users[i]);
    users[i].name[15] = '\0';
    for(int k = 0; k < 15; k++) {
      if(users[i].name[k] == '\0') break;
      if(users[i].name[k] < 32 || users[i].name[k] > 126) users[i].name[k] = '?';
    }
    isCardActive[i] = (EEPROM.read(220 + i) != 0x00); 
  }
}

