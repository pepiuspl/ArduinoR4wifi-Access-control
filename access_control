String getFormattedSystemTime() {
  RTCTime currentRTCTime;
  if (RTC.getTime(currentRTCTime)) {
    char timeBuffer[6];
    sprintf(timeBuffer, "%02d:%02d", currentRTCTime.getHour(), currentRTCTime.getMinutes());
    return String(timeBuffer);
  }
  return "--:--";
}

void dispatchWebhookAlert(String category, String logData) {
  if (strlen(webhook_server) < 4 || WiFi.status() != WL_CONNECTED) return;
  WiFiClient alertClient;
  alertClient.setTimeout(250);
  if (alertClient.connect(webhook_server, 80)) {
    alertClient.println("POST /webhook HTTP/1.1");
    alertClient.print("Host: "); alertClient.println(webhook_server);
    alertClient.println("Content-Type: application/json; charset=utf-8");
    String payload = "{\"event\":\"" + category + "\",\"message\":\"" + logData + "\",\"time\":\"" + getFormattedSystemTime() + "\"}";
    alertClient.print("Content-Length: "); alertClient.println(payload.length());
    alertClient.println("Connection: close");
    alertClient.println();
    alertClient.print(payload);
    alertClient.flush(); alertClient.stop();
  }
}

