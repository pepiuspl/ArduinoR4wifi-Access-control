    tone(BUZZER_PIN, 2000, 800); // [cite: 87]
    delay(1000); // [cite: 87]
    NVIC_SystemReset(); // [cite: 87] 
    return; // [cite: 87]
  } // [cite: 87]

  client.println("HTTP/1.1 200 OK\r\nContent-Type: text/html\r\nConnection: close\r\n"); // [cite: 88]
  client.println("<!DOCTYPE html><html><head><meta charset='utf-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'>"); // [cite: 88]
  client.println("<style>body{background:#121212;color:#fff;font-family:sans-serif;padding:20px;} .box{background:#1e1e1e;padding:20px;border-radius:10px;max-width:400px;margin:20px auto;} input{display:block;width:92%;padding:12px;margin:12px auto;background:#2d2d2d;color:#fff;border:1px solid #444;border-radius:6px;}</style></head><body>"); // [cite: 88]
