    }
    uint32_t receivedBytes = 0; // [cite: 121]
    unsigned long receiveDeadline = millis() + 120000; // [cite: 121]
    while (receivedBytes < contentLength && millis() < receiveDeadline) { // [cite: 122]
        while (client.available()) { // [cite: 122]
