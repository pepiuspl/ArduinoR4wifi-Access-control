  String reqHeader = ""; // [cite: 77]
  unsigned long webTimeout = millis() + 2000; // [cite: 78] 
  while (client.connected() && millis() < webTimeout) { // [cite: 78] 
    if (client.available()) { // [cite: 78]
      char c = client.read(); // [cite: 78]
      reqHeader += c; // [cite: 79]
      if (c == '\n') break; // [cite: 79] 
    } // [cite: 79]
  } // [cite: 79]
  while (client.available()) { client.read(); // [cite: 80]
  } // [cite: 80]
  addLog("REQ=" + reqHeader); // [cite: 80]

  if (reqHeader.indexOf("POST /save_setup") != -1 || reqHeader.indexOf("GET /save_setup") != -1) { // [cite: 80]
    int sIdx = reqHeader.indexOf("s=") + 2; // [cite: 80]
    int pIdx = reqHeader.indexOf("&p=") + 3; // [cite: 81]
    int aIdx = reqHeader.indexOf("&a=") + 3; // [cite: 81]
    int tiIdx = reqHeader.indexOf("&ti=") + 4; // [cite: 81]
    int tpIdx = reqHeader.indexOf("&tp=") + 4; // [cite: 82]
    int teIdx = reqHeader.indexOf("&te="); // [cite: 82]
    String rawSSID = reqHeader.substring(sIdx, reqHeader.indexOf("&p=")); // [cite: 82]
    String rawPass = reqHeader.substring(pIdx, reqHeader.indexOf("&a=")); // [cite: 82]
    String rawAdmin = reqHeader.substring(aIdx, reqHeader.indexOf("&ti=")); // [cite: 83]
    String rawTeleIP = reqHeader.substring(tiIdx, reqHeader.indexOf("&tp=")); // [cite: 83]
    int spacePos = reqHeader.indexOf(" ", tpIdx); // [cite: 83]
    int nextAmp = reqHeader.indexOf("&", tpIdx); // [cite: 84]
    int endPortPos = (nextAmp != -1 && nextAmp < spacePos) ? nextAmp : spacePos; // [cite: 84]
    String nTelePort = reqHeader.substring(tpIdx, endPortPos); // [cite: 85]
    bool runTele = (teIdx != -1); // [cite: 85]
    String decodedSSID = urlDecode(rawSSID); // [cite: 85]
    String decodedPass = urlDecode(rawPass); // [cite: 85]
    String decodedAdmin = urlDecode(rawAdmin); // [cite: 86]
