void sendExternalTelemetry(String logData) { // [cite: 68]
  if (blockTelemetry || !telemetryEnabled || WiFi.status() != WL_CONNECTED) return; // [cite: 69]
  WiFiClient telemetryClient; // [cite: 69]
  telemetryClient.setTimeout(150); // [cite: 69]
  if (telemetryClient.connect(proxmox_log_server, proxmox_log_port)) { // [cite: 69]
    telemetryClient.println("POST /log HTTP/1.1"); // [cite: 69]
    telemetryClient.print("Host: "); telemetryClient.println(proxmox_log_server); // [cite: 70]
    telemetryClient.println("Content-Type: text/plain; charset=utf-8"); // [cite: 70]
    telemetryClient.print("Content-Length: "); telemetryClient.println(logData.length()); // [cite: 70]
    telemetryClient.println("Connection: close\r\n"); // [cite: 71]
    telemetryClient.print(logData); // [cite: 71]
    telemetryClient.flush(); // [cite: 71]
    telemetryClient.stop(); // [cite: 71]
  } // [cite: 71]
} // [cite: 71]

void addLog(String msg) { // [cite: 71]
  RTCTime currentRTCTime; // [cite: 71]
  RTC.getTime(currentRTCTime); // [cite: 71]
  char timeBuffer[12]; // [cite: 71]
  sprintf(timeBuffer, "%02d:%02d:%02d", currentRTCTime.getHour(), currentRTCTime.getMinutes(), currentRTCTime.getSeconds()); // [cite: 71]
  String currentTime = String(timeBuffer); // [cite: 72]
  if (logCount < MAX_LOGS) { // [cite: 72]
    lastActions[logCount++] = {currentTime, msg}; // [cite: 72]
  } else { // [cite: 72]
    for (int i = 0; i < MAX_LOGS - 1; i++) { // [cite: 73]
      lastActions[i] = lastActions[i+1]; // [cite: 73]
    } // [cite: 73]
    lastActions[MAX_LOGS - 1] = {currentTime, msg}; // [cite: 74]
  } // [cite: 74]
  sendExternalTelemetry(msg); // [cite: 74]
} // [cite: 74]

