  client.println("<input type='password' name='p' value='" + String(pass) + "' placeholder='Password' required>"); // [cite: 91]
  client.println("<input type='password' name='a' value='" + String(admin_password) + "' placeholder='Admin Master Password' required>"); // [cite: 92]
