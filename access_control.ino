void executeCloudSynchronization() { // [cite: 189]
  if (strlen(proxmox_log_server) < 4) return; // [cite: 190]
  WiFiClient httpCheck; // [cite: 190] 
  httpCheck.setTimeout(250); // [cite: 190]
  if (!httpCheck.connect(proxmox_log_server, proxmox_log_port)) { // [cite: 191]
    if (millis() - lastSuccessfulPollTime > 30000) { // [cite: 191]
      isOfflineStandby = true; // [cite: 191]
      displayProvisioningInstructions("ERR: CLOUD LOSS"); // [cite: 192] 
      WiFi.disconnect(); // [cite: 192] 
      delay(500); // [cite: 192] 
      WiFi.beginAP("ZAMEK_SETUP"); // [cite: 192] 
      server.begin(); // [cite: 192]
    } // [cite: 192]
    return; // [cite: 192]
  } // [cite: 192]
  lastSuccessfulPollTime = millis(); // [cite: 192]
  String pollPath = "/api/hardware/poll?version=" + urlEncode(String(app_version)); // [cite: 193]
  httpCheck.println("GET " + pollPath + " HTTP/1.1"); // [cite: 193]
  httpCheck.print("Host: "); httpCheck.println(proxmox_log_server); // [cite: 193]
  httpCheck.println("Connection: close\r\n"); // [cite: 193]
  unsigned long deadline = millis() + 300; // [cite: 194] 
  String payloadResponse = ""; // [cite: 194]
  while ((httpCheck.available() || httpCheck.connected()) && millis() < deadline) { // [cite: 195]
    if (httpCheck.available()) { // [cite: 195] 
      char c = httpCheck.read(); // [cite: 195]
      payloadResponse += c; // [cite: 196] 
    } // [cite: 196]
  } // [cite: 196]
  httpCheck.stop(); // [cite: 196]
  
  bool serverUnlockSignal = (payloadResponse.indexOf("\"unlock\":true") != -1);
  bool serverLearnSignal  = (payloadResponse.indexOf("\"learn\":true") != -1);

  if (serverUnlockSignal) { // [cite: 196]
    if (!doorOpen) openDoor("Zdalne Wywolanie"); // [cite: 196]
  } // [cite: 197]
  if (serverLearnSignal) { // [cite: 197]
    learningMode = true; // [cite: 197]
    int userStart = payloadResponse.indexOf("\"username\":\""); // [cite: 198] 
    int userEnd = payloadResponse.indexOf("\"", userStart + 12); // [cite: 198]
    if (userStart > -1 && userEnd > userStart) { // [cite: 199]
      pendingUsername = payloadResponse.substring(userStart + 12, userEnd); // [cite: 199]
    } // [cite: 200]
  } else { // [cite: 200]
    learningMode = false; // [cite: 200]
  } // [cite: 201]
} // [cite: 201]

void transmitCardPayloadToCloud(String uidStr, byte* rawUid, bool runRegister) { // [cite: 201]
  if (strlen(proxmox_log_server) < 4) return; // [cite: 201]
  WiFiClient httpPost; // [cite: 201] 
  httpPost.setTimeout(400); // [cite: 201]
  if (!httpPost.connect(proxmox_log_server, proxmox_log_port)) return; // [cite: 202] 
  String endpoint = runRegister ? "/api/hardware/register" : "/api/hardware/scan"; // [cite: 202]
  String postData = runRegister ? // [cite: 202]
  "{\"uid\":\"" + uidStr + "\",\"name\":\"" + pendingUsername + "\"}" : "{\"uid\":\"" + uidStr + "\"}"; // [cite: 203]
  httpPost.println("POST " + endpoint + " HTTP/1.1"); // [cite: 204] 
  httpPost.print("Host: "); httpPost.println(proxmox_log_server); // [cite: 204]
  httpPost.println("Content-Type: application/json"); // [cite: 204] 
  httpPost.print("Content-Length: "); httpPost.println(postData.length()); // [cite: 204]
  httpPost.println("Connection: close\r\n"); // [cite: 204] 
  httpPost.print(postData); // [cite: 204]
  unsigned long deadline = millis() + 400; // [cite: 205] 
  String payloadResponse = ""; // [cite: 205]
