String urlEncode(String str) { // [cite: 6]
  String encoded = ""; // [cite: 7]
  char c; // [cite: 7]
  char hex[3]; // [cite: 7]
  for (unsigned int i = 0; i < str.length(); i++) { // [cite: 8]
    c = str[i]; // [cite: 8]
    if (isalnum(c) || c == '-' || c == '_' || c == '.' || c == '~') { // [cite: 9]
      encoded += c; // [cite: 9]
    } else if (c == ' ') { // [cite: 10]
      encoded += '+'; // [cite: 10]
    } else { // [cite: 11]
      sprintf(hex, "%%%02X", c); // [cite: 11]
      encoded += hex; // [cite: 11]
    } // [cite: 11]
  } // [cite: 8]
  return encoded; // [cite: 11]
} // [cite: 12]

